@model TradingCourse.Web.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Trade with clarity";
    var banners = Model.Banners ?? System.Array.Empty<TradingCourse.Application.Models.HomepageBanner>();
    var bannerList = banners.ToList();
    var hasBanners = bannerList.Any();
    var defaultHeading = "Trade smarter. Build your edge.";
    var defaultCopy = "Practical trading education, live market clarity, and a disciplined path to your next level.";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/lenis@1.1.13/dist/lenis.css">
    <style>
        .hero-carousel { min-height: 600px; position: relative; }
        .hero-carousel .carousel-item { min-height: 600px; position: relative; }
        .hero-carousel .carousel-item img,
        .hero-carousel .carousel-item video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
        .hero-carousel .carousel-item .carousel-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(11,15,25,0.35) 0%, rgba(11,15,25,0.9) 100%); z-index: 2; }
        .hero-carousel .carousel-caption-custom { position: relative; z-index: 3; }
        .hero-carousel .carousel-indicators { z-index: 4; margin-bottom: 1.5rem; }
        .hero-carousel .carousel-indicators [data-bs-target] { width: 32px; height: 4px; border-radius: 2px; background: rgba(255,255,255,0.4); border: 0; opacity: 1; }
        .hero-carousel .carousel-indicators .active { background: #2dd4bf; }
        .hero-carousel .carousel-control-prev,
        .hero-carousel .carousel-control-next { width: 48px; height: 48px; border-radius: 50%; background: rgba(11,15,25,0.6); border: 1px solid rgba(255,255,255,0.15); top: 50%; transform: translateY(-50%); margin: 0 16px; opacity: 0; transition: opacity .3s; }
        .hero-carousel:hover .carousel-control-prev,
        .hero-carousel:hover .carousel-control-next { opacity: 1; }
        .hero-carousel .carousel-control-prev-icon,
        .hero-carousel .carousel-control-next-icon { filter: invert(1); width: 1.2rem; height: 1.2rem; }
        .course-track { display: flex; gap: 20px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 16px; scrollbar-width: none; }
        .course-track::-webkit-scrollbar { display: none; }
        .course-track .course-slide { flex: 0 0 calc(25% - 15px); min-width: 260px; scroll-snap-align: start; }
        @@media (max-width: 991px) { .course-track .course-slide { flex: 0 0 calc(33.333% - 14px); } }
        @@media (max-width: 600px) { .course-track .course-slide { flex: 0 0 85%; } }
    </style>
}

<section class="hero-carousel" id="homepage-slider">
    @if (hasBanners)
    {
        <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="6000">
            <div class="carousel-indicators">
                @for (int i = 0; i < bannerList.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (int i = 0; i < bannerList.Count; i++)
                {
                    var b = bannerList[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        @if (b.MediaType == "Video" && !string.IsNullOrEmpty(b.MediaUrl))
                        {
                            <video autoplay loop muted playsinline><source src="@b.MediaUrl" type="video/mp4" /></video>
                        }
                        else if (b.MediaType == "Photo" && !string.IsNullOrEmpty(b.MediaUrl))
                        {
                            <img src="@b.MediaUrl" alt="@b.Heading" loading="@(i == 0 ? "eager" : "lazy")" />
                        }
                        <div class="carousel-overlay"></div>
                        <div class="container carousel-caption-custom d-flex align-items-center" style="min-height: 600px;">
                            <div class="py-5" style="max-width: 640px;">
                                <div class="eyebrow mb-3"><span class="eyebrow-dot"></span> Apsra Trading Academy</div>
                                <h1 class="text-white" style="font-size: clamp(2.6rem, 4.4vw, 4.4rem); line-height: .98; margin: 16px 0 20px;">@b.Heading</h1>
                                <p class="text-secondary mb-4" style="line-height: 1.8; max-width: 520px; font-size: 1rem;">@b.Subheading</p>
                                <div class="d-flex gap-3 flex-wrap">
                                    @if (!string.IsNullOrEmpty(b.ButtonUrl))
                                    {
                                        <a href="@b.ButtonUrl" class="btn btn-brand">@(string.IsNullOrEmpty(b.ButtonText) ? "Explore programs" : b.ButtonText) <i class="bi bi-arrow-up-right"></i></a>
                                    }
                                    <a href="#academy-features" class="btn btn-quiet">How we teach <i class="bi bi-play-circle"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon" aria-hidden="true"></span><span class="visually-hidden">Previous</span></button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next"><span class="carousel-control-next-icon" aria-hidden="true"></span><span class="visually-hidden">Next</span></button>
        </div>
    }
    else
    {
        <div class="container d-flex align-items-center" style="min-height: 600px; position: relative; z-index: 2;">
            <div class="py-5" style="max-width: 640px;">
                <div class="eyebrow mb-3"><span class="eyebrow-dot"></span> Apsra Trading Academy</div>
                <h1 class="text-white" style="font-size: clamp(2.6rem, 4.4vw, 4.4rem); line-height: .98; margin: 16px 0 20px;">@defaultHeading</h1>
                <p class="text-secondary mb-4" style="line-height: 1.8; max-width: 520px; font-size: 1rem;">@defaultCopy</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Course" asp-action="Index" class="btn btn-brand">Explore programs <i class="bi bi-arrow-up-right"></i></a>
                    <a href="#academy-features" class="btn btn-quiet">How we teach <i class="bi bi-play-circle"></i></a>
                </div>
            </div>
        </div>
    }
</section>

<section class="trusted-strip" aria-label="Academy benefits">
    <span>REAL-WORLD LEARNING</span><i></i>
    <span>LIVE MARKET CONTEXT</span><i></i>
    <span>RISK-FIRST PROCESS</span><i></i>
    <span>DESIGNED FOR DISCIPLINE</span>
</section>

<section class="feature-section" id="academy-features">
    <div class="section-heading">
        <div>
            <span class="eyebrow">The Apsra approach</span>
            <h2>Learn the craft behind<br />confident decisions.</h2>
        </div>
        <p>Market knowledge is only useful when it becomes a repeatable process. Our training brings theory, execution, and risk together.</p>
    </div>
    <div class="feature-grid">
        <article class="feature-card">
            <span class="feature-icon"><i class="bi bi-person-check"></i></span>
            <span class="feature-count">01</span>
            <h3>Expert-led clarity</h3>
            <p>Learn from market professionals who make complex setups understandable and actionable.</p>
        </article>
        <article class="feature-card feature-card-highlight">
            <span class="feature-icon"><i class="bi bi-broadcast"></i></span>
            <span class="feature-count">02</span>
            <h3>Live market rooms</h3>
            <p>See preparation, analysis, and execution in context — not just after the chart has moved.</p>
        </article>
        <article class="feature-card">
            <span class="feature-icon"><i class="bi bi-shield-check"></i></span>
            <span class="feature-count">03</span>
            <h3>Risk comes first</h3>
            <p>Build the habits that protect capital and help your edge compound over time.</p>
        </article>
    </div>
</section>

@if (Model.Courses != null && Model.Courses.Any())
{
    <section class="courses-slider-section py-5">
        <div class="container">
            <div class="section-heading mb-4">
                <div>
                    <span class="eyebrow">Programs</span>
                    <h2>Start your next cohort</h2>
                </div>
                <a asp-controller="Course" asp-action="Index" class="btn btn-brand">View all programs <i class="bi bi-arrow-up-right"></i></a>
            </div>

            <div class="course-track" id="courseTrack">
                @foreach (var course in Model.Courses)
                {
                    <div class="course-slide">
                        <div class="glass-card h-100 d-flex flex-column justify-content-between p-4">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    @if (course.IsLive)
                                    {
                                        <span class="live-indicator"><span class="live-dot"></span> LIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom">Self-Paced</span>
                                    }
                                    <small class="text-muted"><i class="bi bi-clock"></i> @course.Schedule</small>
                                </div>

                                <h3 class="text-white h4 mb-2">@course.Title</h3>
                                <p class="text-secondary small mb-3">By <strong>@course.Instructor</strong></p>

                                <p class="text-secondary text-sm mb-4">@course.ShortDescription</p>
                            </div>

                            <div>
                                <hr class="border-secondary opacity-25 my-3" />
                                
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="d-block text-muted small">Course Fee</span>
                                        <span class="fs-5 fw-bold text-white">
                                            @if (course.SalePrice.HasValue)
                                            {
                                                <span class="text-decoration-line-through text-muted small me-2">₹@course.Price.ToString("N2")</span>
                                                <span style="color: var(--accent-cyan);">₹@course.SalePrice.Value.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span style="color: var(--accent-cyan);">₹@course.Price.ToString("N2")</span>
                                            }
                                        </span>
                                    </div>
                                    <a asp-controller="Course" asp-action="Details" asp-route-slug="@course.Slug" class="btn btn-premium">
                                        Details <i class="bi bi-arrow-right-short"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@section Scripts {
    <!-- Dynamic Scroll and GSAP/ScrollTrigger Motion Control -->
    <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Respect user preference for reduced motion
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (prefersReducedMotion) return;

            // 1. Lenis Smooth Scroll Setup
            const lenis = new Lenis({
                duration: 1.2,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // easeOutExpo
                direction: 'vertical',
                gestureDirection: 'vertical',
                smoothShift: true,
                smoothWheel: true,
                wheelMultiplier: 1.0
            });

            function raf(time) {
                lenis.raf(time);
                requestAnimationFrame(raf);
            }
            requestAnimationFrame(raf);

            // Connect Lenis scroll callback to GSAP ScrollTrigger updates
            lenis.on('scroll', ScrollTrigger.update);

            gsap.ticker.add((time) => {
                lenis.raf(time * 1000);
            });
            gsap.ticker.lagSmoothing(0);

            // 2. GSAP Plugins Registration
            gsap.registerPlugin(ScrollTrigger);

            // 3. Hero Section Page Load Animation
            const heroTL = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });
            const isActiveCarousel = document.querySelector('#heroCarousel') !== null;
            const heroSelectorPrefix = isActiveCarousel ? '.carousel-item.active' : '.hero-carousel .container';

            heroTL.from(`${heroSelectorPrefix} .eyebrow`, {
                y: 35,
                opacity: 0,
                delay: 0.3
            })
            .from(`${heroSelectorPrefix} h1`, {
                y: 50,
                opacity: 0,
                duration: 1.4
            }, '-=0.9')
            .from(`${heroSelectorPrefix} p`, {
                y: 35,
                opacity: 0
            }, '-=1.0')
            .from(`${heroSelectorPrefix} .d-flex.gap-3 a`, {
                y: 25,
                opacity: 0,
                stagger: 0.15
            }, '-=0.9')
            .from(`${heroSelectorPrefix} img, ${heroSelectorPrefix} video`, {
                scale: 1.12,
                opacity: 0,
                duration: 1.8
            }, '-=1.6');

            // 4. Hero Content Interactive Mouse Movement (Parallax)
            const heroSection = document.querySelector('.hero-carousel');
            if (heroSection) {
                heroSection.addEventListener('mousemove', (e) => {
                    const { clientX, clientY } = e;
                    const rect = heroSection.getBoundingClientRect();
                    const xOffset = ((clientX - rect.left) / rect.width - 0.5) * 26; // max shift 13px
                    const yOffset = ((clientY - rect.top) / rect.height - 0.5) * 26;
                    
                    gsap.to(`${heroSelectorPrefix} .py-5`, {
                        x: xOffset,
                        y: yOffset,
                        duration: 0.8,
                        ease: 'power2.out'
                    });
                    
                    gsap.to(`${heroSelectorPrefix} img, ${heroSelectorPrefix} video`, {
                        x: -xOffset * 0.3,
                        y: -yOffset * 0.3,
                        duration: 0.8,
                        ease: 'power2.out'
                    });
                });
                
                heroSection.addEventListener('mouseleave', () => {
                    gsap.to(`${heroSelectorPrefix} .py-5`, {
                        x: 0,
                        y: 0,
                        duration: 0.8,
                        ease: 'power2.out'
                    });
                    gsap.to(`${heroSelectorPrefix} img, ${heroSelectorPrefix} video`, {
                        x: 0,
                        y: 0,
                        duration: 0.8,
                        ease: 'power2.out'
                    });
                });
            }

            // 5. Bootstrap Carousel Transition Animation Reset
            const carouselEl = document.querySelector('#heroCarousel');
            if (carouselEl) {
                carouselEl.addEventListener('slid.bs.carousel', (e) => {
                    const activeItem = e.relatedTarget;
                    
                    // Reset elements for animation re-entry
                    gsap.killTweensOf(activeItem.querySelectorAll('.eyebrow, h1, p, .d-flex.gap-3 a, img, video'));
                    gsap.set(activeItem.querySelectorAll('.eyebrow, h1, p, .d-flex.gap-3 a'), { y: 0, opacity: 1, x: 0 });
                    gsap.set(activeItem.querySelectorAll('img, video'), { scale: 1, opacity: 1, x: 0 });
                    
                    // Animate current slide
                    const slideTL = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });
                    slideTL.from(activeItem.querySelector('.eyebrow'), { y: 35, opacity: 0, delay: 0.1 })
                           .from(activeItem.querySelector('h1'), { y: 50, opacity: 0, duration: 1.4 }, '-=0.9')
                           .from(activeItem.querySelector('p'), { y: 35, opacity: 0 }, '-=1.0')
                           .from(activeItem.querySelectorAll('.d-flex.gap-3 a'), { y: 25, opacity: 0, stagger: 0.15 }, '-=0.9')
                           .from(activeItem.querySelectorAll('img, video'), { scale: 1.12, opacity: 0, duration: 1.8 }, '-=1.6');
                });
            }

            // 6. Section Scroll-Triggered Fade & Slide Reveals
            const sections = gsap.utils.toArray('.trusted-strip, .feature-section, .courses-slider-section');
            sections.forEach(section => {
                gsap.from(section, {
                    opacity: 0,
                    y: 60,
                    scale: 0.98,
                    duration: 1.2,
                    ease: 'power3.out',
                    scrollTrigger: {
                        trigger: section,
                        start: 'top 85%',
                        toggleActions: 'play none none none'
                    }
                });
            });

            // 7. Staggered reveal for Feature Cards
            gsap.from('.feature-grid .feature-card', {
                opacity: 0,
                y: 50,
                scale: 0.95,
                stagger: 0.15,
                duration: 1.0,
                ease: 'power3.out',
                scrollTrigger: {
                    trigger: '.feature-grid',
                    start: 'top 85%',
                    toggleActions: 'play none none none'
                }
            });

            // 8. Staggered reveal for Course Cards inside course track
            gsap.from('.course-track .course-slide', {
                opacity: 0,
                y: 50,
                scale: 0.96,
                stagger: 0.15,
                duration: 1.0,
                ease: 'power3.out',
                scrollTrigger: {
                    trigger: '.courses-slider-section',
                    start: 'top 75%',
                    toggleActions: 'play none none none'
                }
            });

            // 9. Count-Up Stat Animations for Feature Card numbers
            gsap.utils.toArray('.feature-count').forEach(counter => {
                const targetVal = parseInt(counter.textContent) || 0;
                if (isNaN(targetVal)) return;
                
                const obj = { val: 0 };
                gsap.to(obj, {
                    val: targetVal,
                    duration: 1.8,
                    ease: 'power2.out',
                    scrollTrigger: {
                        trigger: counter,
                        start: 'top 90%',
                        toggleActions: 'play none none none'
                    },
                    onUpdate: () => {
                        counter.textContent = String(Math.floor(obj.val)).padStart(2, '0');
                    }
                });
            });

            // 10. Magnetic Button Hover Feel (GSAP Physics)
            const magneticButtons = document.querySelectorAll('.btn-brand, .btn-quiet, .btn-premium, .nav-cta');
            magneticButtons.forEach(btn => {
                btn.addEventListener('mousemove', function(e) {
                    const rect = this.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;
                    
                    gsap.to(this, {
                        x: x * 0.35,
                        y: y * 0.35,
                        duration: 0.35,
                        ease: 'power2.out'
                    });
                });
                btn.addEventListener('mouseleave', function() {
                    gsap.to(this, {
                        x: 0,
                        y: 0,
                        duration: 0.6,
                        ease: 'elastic.out(1, 0.3)'
                    });
                });
            });

            // 11. Generic/Fallback Animators (Accordion FAQ & Testimonials)
            // Accordion Trigger
            document.querySelectorAll('.faq-trigger, .faq-header').forEach(trigger => {
                trigger.addEventListener('click', function() {
                    const item = this.closest('.faq-item');
                    if (!item) return;
                    
                    const content = item.querySelector('.faq-content');
                    if (!content) return;
                    
                    const isOpen = content.classList.contains('is-open');
                    
                    // Close other FAQs in the same container
                    const container = item.closest('.faq-container, .faq-list');
                    if (container) {
                        container.querySelectorAll('.faq-content.is-open').forEach(openContent => {
                            openContent.classList.remove('is-open');
                            gsap.to(openContent, { height: 0, opacity: 0, duration: 0.4, ease: 'power2.out' });
                        });
                        container.querySelectorAll('.faq-item.is-open').forEach(openItem => {
                            openItem.classList.remove('is-open');
                        });
                    }
                    
                    if (!isOpen) {
                        item.classList.add('is-open');
                        content.classList.add('is-open');
                        
                        // Animate open
                        gsap.killTweensOf(content);
                        gsap.fromTo(content, 
                            { height: 0, opacity: 0 }, 
                            { height: 'auto', opacity: 1, duration: 0.4, ease: 'power2.out' }
                        );
                    }
                });
            });

            // Testimonials
            gsap.utils.toArray('.testimonials-slider, .testimonial-track').forEach(slider => {
                const slides = slider.querySelectorAll('.testimonial-card, .testimonial-slide');
                if (slides.length <= 1) return;
                
                let activeIndex = 0;
                
                function transitionTo(nextIndex) {
                    const currentSlide = slides[activeIndex];
                    const nextSlide = slides[nextIndex];
                    const direction = nextIndex > activeIndex ? 1 : -1;
                    
                    gsap.to(currentSlide, {
                        opacity: 0,
                        x: -50 * direction,
                        duration: 0.5,
                        ease: 'power2.inOut',
                        onComplete: () => {
                            currentSlide.style.display = 'none';
                        }
                    });
                    
                    nextSlide.style.display = 'block';
                    gsap.fromTo(nextSlide, 
                        { opacity: 0, x: 50 * direction },
                        { opacity: 1, x: 0, duration: 0.5, ease: 'power2.inOut' }
                    );
                    
                    activeIndex = nextIndex;
                }
                
                setInterval(() => {
                    const nextIdx = (activeIndex + 1) % slides.length;
                    transitionTo(nextIdx);
                }, 5000);
            });
        });
    </script>
}
