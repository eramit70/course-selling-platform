@model IEnumerable<TradingCourse.Application.Models.Course>
@{
    ViewData["Title"] = "Explore Courses";
}

<div class="py-5">
    <div class="text-center mb-5">
        <h1 class="text-white display-4 fw-bold">Professional Trading Programs</h1>
        <p class="text-secondary fs-5">Elevate your understanding of the financial markets with structured live training</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="glass-card text-center py-5" id="no-courses-card">
            <i class="bi bi-journal-x fs-1 text-muted mb-3 d-block"></i>
            <h3 class="text-white">No Courses Available</h3>
            <p class="text-secondary">We are preparing new cohorts. Please check back later or contact support to get notified.</p>
        </div>
    }
    else
    {
        <div class="row g-4" id="courses-grid">
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="glass-card h-100 d-flex flex-column justify-content-between p-0 overflow-hidden" id="course-card-@course.Id">
                        @if (!string.IsNullOrEmpty(course.MediaUrl))
                        {
                            <div style="height: 180px; position: relative; border-bottom: 1px solid var(--line);">
                                @if (course.MediaType == "Video")
                                {
                                    <div class="w-100 h-100 bg-dark d-flex align-items-center justify-content-center">
                                        <i class="bi bi-play-circle text-secondary" style="font-size: 3rem;"></i>
                                    </div>
                                }
                                else
                                {
                                    <img src="@course.MediaUrl" alt="@course.Title" class="w-100 h-100 object-fit-cover" />
                                }
                            </div>
                        }
                        <div class="p-4 d-flex flex-column justify-content-between flex-grow-1">
                            <div>
                                <!-- Title -->
                                <h3 class="text-white h5 mb-3 fw-bold" style="line-height: 1.4;">@course.Title</h3>
                                
                                <!-- Basic Info -->
                                <ul class="list-unstyled mb-4">
                                    <li class="d-flex align-items-start mb-2">
                                        <i class="bi bi-person-video3 text-muted me-2 mt-1"></i>
                                        <span class="text-secondary small">Instructor: @course.Instructor</span>
                                    </li>
                                    <li class="d-flex align-items-start">
                                        <i class="bi bi-calendar-event text-muted me-2 mt-1"></i>
                                        <span class="text-secondary small">@course.Schedule</span>
                                    </li>
                                </ul>
                            </div>
                            
                            <div>
                                <hr class="border-secondary opacity-25 mt-0 mb-3" />
                                
                                <!-- Pricing -->
                                <div class="mb-3">
                                    @if (course.SalePrice.HasValue)
                                    {
                                        <span class="fs-4 fw-bold text-white">₹@course.SalePrice.Value.ToString("N2")</span>
                                        <span class="text-decoration-line-through text-muted small ms-2">₹@course.Price.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="fs-4 fw-bold text-white">₹@course.Price.ToString("N2")</span>
                                    }
                                    <span class="d-block text-muted" style="font-size: 0.65rem;">(ONE-TIME FEE)</span>
                                </div>
                                
                                <!-- Actions -->
                                <div class="d-flex gap-2">
                                    <a asp-controller="Course" asp-action="Details" asp-route-slug="@course.Slug" class="btn flex-grow-1 text-uppercase fw-bold text-center" style="font-size: 0.75rem; padding: 0.7rem 0; border: 1px solid var(--accent-cyan); color: var(--accent-cyan);">
                                        Explore
                                    </a>
                                    <a asp-controller="Course" asp-action="Checkout" asp-route-slug="@course.Slug" class="btn btn-brand flex-grow-1 text-uppercase fw-bold text-center" style="font-size: 0.75rem; padding: 0.7rem 0;">
                                        Book a Seat
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
