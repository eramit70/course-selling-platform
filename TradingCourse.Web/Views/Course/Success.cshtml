@model TradingCourse.Application.Models.Order
@{
    ViewData["Title"] = "Enrollment Successful";
}

<div class="py-5 text-center">
    <div class="glass-card max-width-600 mx-auto py-5 px-4" id="success-confirmation-card" style="max-width: 650px;">
        <div class="mb-4">
            <i class="bi bi-patch-check-fill" style="font-size: 5rem; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 15px rgba(20, 184, 166, 0.4));"></i>
        </div>

        <h1 class="text-white fw-bold mb-3" id="success-title">Enrollment Successful!</h1>
        <p class="text-secondary fs-5 mb-4">Welcome to the cohort. You have successfully enrolled in <strong>@Model.Course.Title</strong>.</p>

        <!-- Receipt Box -->
        <div class="border border-secondary border-opacity-10 rounded p-4 mb-4 text-start bg-black bg-opacity-25" id="receipt-details">
            <h4 class="text-white mb-3 h5 border-bottom border-secondary border-opacity-10 pb-2">Enrollment Receipt</h4>
            
            <div class="row g-2 text-secondary small">
                <div class="col-sm-4"><strong>Order ID:</strong></div>
                <div class="col-sm-8 text-white font-monospace" id="receipt-order-id">#@Model.Id</div>

                <div class="col-sm-4"><strong>Student Name:</strong></div>
                <div class="col-sm-8 text-white" id="receipt-name">@Model.CustomerName</div>

                <div class="col-sm-4"><strong>Student Email:</strong></div>
                <div class="col-sm-8 text-white text-break" id="receipt-email">@Model.CustomerEmail</div>

                <div class="col-sm-4"><strong>Amount Paid:</strong></div>
                <div class="col-sm-8 text-white fw-bold" id="receipt-amount">₹@Model.AmountPaid.ToString("N2")</div>

                <div class="col-sm-4"><strong>Payment ID:</strong></div>
                <div class="col-sm-8 text-white font-monospace text-break" id="receipt-payment-id">@Model.RazorpayPaymentId</div>

                <div class="col-sm-4"><strong>Date:</strong></div>
                <div class="col-sm-8 text-white" id="receipt-date">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</div>
            </div>
        </div>

        <!-- Schedule / Join Link Box -->
        <div class="border border-secondary border-opacity-10 rounded p-4 mb-4 text-start bg-black bg-opacity-25" id="joining-details">
            <h4 class="text-white mb-3 h5 border-bottom border-secondary border-opacity-10 pb-2">Class Joining Details</h4>
            
            <div class="row g-2 text-secondary small">
                <div class="col-sm-4"><strong>Instructor:</strong></div>
                <div class="col-sm-8 text-white">@Model.Course.Instructor</div>

                <div class="col-sm-4"><strong>Schedule:</strong></div>
                <div class="col-sm-8 text-white">@Model.Course.Schedule</div>

                @if (!string.IsNullOrEmpty(Model.Course.LiveClassLink))
                {
                    <div class="col-sm-4"><strong>Live Class Link:</strong></div>
                    <div class="col-sm-8">
                        <a href="@Model.Course.LiveClassLink" target="_blank" class="text-cyan text-decoration-none fw-semibold" id="receipt-live-link">
                            Join Live Classroom <i class="bi bi-box-arrow-up-right ms-1"></i>
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="alert alert-info bg-info bg-opacity-10 border-info border-opacity-20 text-info small mb-4 text-start" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i>
            We've queued your digital enrollment kit. An email contains your schedule, live class joining links, and course materials will arrive at <strong>@Model.CustomerEmail</strong> shortly.
        </div>

        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-premium" id="btn-back-home">
                Back to Home
            </a>
            <a asp-controller="Course" asp-action="Index" class="btn btn-outline-custom" id="btn-view-courses">
                Explore More Courses
            </a>
        </div>
    </div>
</div>
