@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="py-5 text-center">
    <div class="glass-card d-inline-block p-5" style="max-width: 600px;">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
        <h1 class="text-white mt-4 mb-3">Oops! Something went wrong.</h1>
        <p class="text-secondary fs-5 mb-4">
            An unexpected error occurred while processing your request. Please contact the administrator.
        </p>
        
        @if (Model != null && Model.ShowRequestId)
        {
            <p class="text-muted small">
                <strong>Error Reference ID:</strong> <code>@Model.RequestId</code>
            </p>
        }
        
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-premium">
                <i class="bi bi-house-door me-2"></i> Return to Homepage
            </a>
        </div>
    </div>
</div>
