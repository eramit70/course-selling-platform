@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var themeMode = Configuration["ThemeSettings:Mode"] ?? Configuration["Theme"] ?? "dark";
    if (string.IsNullOrWhiteSpace(themeMode)) { themeMode = "dark"; }
}
<!DOCTYPE html>
<html lang="en" data-theme="@themeMode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The GrowLog</title>
    <script>document.documentElement.dataset.theme = '@themeMode';</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TradingCourse.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <canvas id="particle-canvas"></canvas>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container nav-shell">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/uploads/logos/header-logo.png" alt="The GrowLog Logo" style="height:40px; margin-right:8px;" />
                    <span>The GrowLog</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <i class="bi bi-list"></i>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Course" asp-action="Index">Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#academy-features">Our approach</a></li>
                    </ul>
                    <div class="nav-actions">
                        <a asp-controller="Course" asp-action="Index" class="nav-cta">Start learning <i class="bi bi-arrow-up-right"></i></a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="page-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>
    <footer class="footer-custom">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/uploads/logos/footer-logo.png" alt="The GrowLog Logo" style="height:40px; margin-right:8px;" />
                <span>The GrowLog</span>
            </a>
            <span>© @DateTime.UtcNow.Year The GrowLog</span>
            <span>Learn deliberately. Trade responsibly.</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
