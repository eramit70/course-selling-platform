@model IEnumerable<TradingCourse.Application.Models.HomepageBanner>
@{
    ViewData["Title"] = "Homepage Slider Settings";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-white fw-bold mb-1">Homepage Slider</h1>
            <p class="text-secondary mb-0">Manage slides, headlines, and background media for the portfolio website</p>
        </div>
        <a asp-action="Create" class="btn btn-premium" id="btn-create-banner">
            <i class="bi bi-plus-lg me-1"></i> Add New Slide
        </a>
    </div>

    <div class="glass-card" id="banner-list-card">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-images text-secondary display-1 mb-3"></i>
                <h4 class="text-white">No Slider Banners Configured</h4>
                <p class="text-secondary">Create your first homepage slide to start building the portfolio slider.</p>
                <a asp-action="Create" class="btn btn-premium mt-3">Add Slide</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" style="border-color: var(--card-border);">
                    <thead>
                        <tr class="text-secondary">
                            <th>Order</th>
                            <th>Media</th>
                            <th>Heading Details</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var banner in Model)
                        {
                            <tr>
                                <td class="align-middle">
                                    <span class="badge bg-secondary">#@banner.DisplayOrder</span>
                                </td>
                                <td class="align-middle">
                                    @if (banner.MediaType == "Photo")
                                    {
                                        <img src="@banner.MediaUrl" alt="Media Preview" class="rounded" style="width: 100px; height: 56px; object-fit: cover; border: 1px solid rgba(255,255,255,0.1);" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-black text-center d-flex align-items-center justify-content-center" style="width: 100px; height: 56px; border: 1px solid rgba(255,255,255,0.1);">
                                            <i class="bi bi-play-btn-fill text-cyan fs-4"></i>
                                        </div>
                                    }
                                </td>
                                <td class="align-middle">
                                    <span class="d-block text-white fw-semibold">@banner.Heading</span>
                                    <span class="text-secondary small d-block text-truncate" style="max-width: 300px;">@banner.Subheading</span>
                                    <span class="badge bg-dark text-cyan border border-info border-opacity-25 mt-1">@banner.MediaType</span>
                                </td>
                                <td class="align-middle">
                                    @if (banner.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-20 text-success border border-success border-opacity-35 px-3 py-2">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-20 text-danger border border-danger border-opacity-35 px-3 py-2">Inactive</span>
                                    }
                                </td>
                                <td class="align-middle text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@banner.Id" class="btn btn-sm btn-outline-custom">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@banner.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this slide?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
