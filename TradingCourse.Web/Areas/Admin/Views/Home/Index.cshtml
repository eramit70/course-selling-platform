@model IEnumerable<TradingCourse.Application.Models.Order>
@{ ViewData["Title"] = "Overview"; }
<style>
    .admin-welcome { align-items:end; display:flex; justify-content:space-between; margin-bottom:30px; }.admin-welcome h1 { font-size:clamp(2.2rem,4vw,3.4rem); line-height:1; margin:9px 0 0; }.admin-welcome p { color:var(--muted); font-size:.78rem; margin:0; }.admin-label { color:var(--muted); font:500 .62rem 'DM Mono',monospace; letter-spacing:.1em; text-transform:uppercase; }.admin-primary-action { background:var(--night); border-radius:6px; color:#fff; font-size:.74rem; font-weight:800; padding:.76rem .95rem; text-decoration:none; }.metrics-grid { display:grid; gap:14px; grid-template-columns:repeat(4,1fr); margin-bottom:28px; }.metric-card { background:var(--surface); border:1px solid var(--line); min-height:145px; padding:19px; }.metric-icon { align-items:center; background:var(--soft); border-radius:5px; color:#1e8c70; display:flex; font-size:.9rem; height:29px; justify-content:center; width:29px; }.metric-card .admin-label { display:block; margin:18px 0 4px; }.metric-card strong { color:var(--ink); display:block; font-size:1.72rem; letter-spacing:-.06em; }.metric-card strong small { color:#28a882; font-size:.63rem; letter-spacing:0; margin-left:3px; }.metric-card.revenue { background:var(--night); }.metric-card.revenue .admin-label { color:#9cb5ab; }.metric-card.revenue strong { color:#fff; }.metric-card.revenue .metric-icon { background:#254c42; color:#70e6be; }.admin-split { display:grid; gap:16px; grid-template-columns:1.4fr .9fr; }.admin-panel { background:var(--surface); border:1px solid var(--line); padding:22px; }.panel-head { align-items:center; display:flex; justify-content:space-between; margin-bottom:18px; }.panel-head h2 { font:700 1rem var(--font-body); letter-spacing:-.03em; margin:0; }.panel-head a { color:#22866d; font-size:.67rem; font-weight:800; text-decoration:none; }.activity-empty { color:var(--muted); font-size:.8rem; padding:55px 0; text-align:center; }.portfolio-card { background:var(--mint); min-height:100%; overflow:hidden; padding:23px; position:relative; }.portfolio-card h2 { font-size:1.55rem; line-height:1.05; margin:8px 0 35px; max-width:240px; }.portfolio-lines { bottom:-5px; height:170px; left:0; opacity:.72; position:absolute; width:100%; }.portfolio-stat { background:color-mix(in srgb,var(--surface) 72%,transparent); border:1px solid color-mix(in srgb,var(--mint-strong) 35%,transparent); border-radius:5px; display:inline-block; font-size:.69rem; font-weight:800; padding:9px 11px; position:relative; z-index:1; }.portfolio-stat span { color:#148465; font-size:.62rem; }.admin-table .badge { font-size:.61rem; font-weight:800; }.admin-table td { vertical-align:middle; } @@media(max-width:991px) { .metrics-grid { grid-template-columns:repeat(2,1fr); }.admin-split { grid-template-columns:1fr; }.portfolio-card { min-height:240px; } } @@media(max-width:576px) { .admin-welcome { align-items:start; flex-direction:column; gap:18px; }.metrics-grid { grid-template-columns:1fr 1fr; }.metric-card { min-height:128px; }.admin-panel { padding:15px; } }
</style>
<section class="admin-welcome"><div><span class="admin-label">Management overview</span><h1>Good to see you.</h1><p>Here’s the current shape of your academy.</p></div><a asp-controller="Course" asp-action="Create" class="admin-primary-action"><i class="bi bi-plus-lg me-1"></i> Create program</a></section>
<section class="metrics-grid"><article class="metric-card"><span class="metric-icon"><i class="bi bi-collection-play"></i></span><span class="admin-label">Programs</span><strong>@ViewBag.TotalCourses</strong></article><article class="metric-card"><span class="metric-icon"><i class="bi bi-ticket-perforated"></i></span><span class="admin-label">Coupons</span><strong>@ViewBag.TotalCoupons</strong></article><article class="metric-card"><span class="metric-icon"><i class="bi bi-people"></i></span><span class="admin-label">Paid enrolments</span><strong>@ViewBag.TotalOrders</strong></article><article class="metric-card revenue"><span class="metric-icon"><i class="bi bi-wallet2"></i></span><span class="admin-label">Revenue collected</span><strong>₹@ViewBag.TotalRevenue.ToString("N2")<small>all time</small></strong></article></section>
<section class="admin-split"><article class="admin-panel"><div class="panel-head"><h2>Recent activity</h2><a asp-controller="Order" asp-action="Index">View enrolments <i class="bi bi-arrow-up-right"></i></a></div>@if (Model == null || !Model.Any()) { <p class="activity-empty">New enrolments will appear here once learners begin joining your programs.</p> } else { <div class="table-responsive"><table class="table admin-table mb-0"><thead><tr><th>Learner</th><th>Program</th><th>Payment</th><th>When</th></tr></thead><tbody>@foreach (var lead in Model) { <tr><td><strong>@lead.CustomerName</strong><span class="d-block text-secondary small">@lead.CustomerEmail</span></td><td>@lead.Course?.Title</td><td>@if (lead.PaymentStatus == TradingCourse.Application.Models.PaymentStatus.Success) { <span class="badge bg-success-subtle text-success-emphasis">Paid</span> } else if (lead.PaymentStatus == TradingCourse.Application.Models.PaymentStatus.Pending) { <span class="badge bg-warning-subtle text-warning-emphasis">Pending</span> } else { <span class="badge bg-danger-subtle text-danger-emphasis">Failed</span> }</td><td class="text-secondary">@lead.CreatedAt.ToLocalTime().ToString("dd MMM")</td></tr> }</tbody></table></div>}</article><aside class="portfolio-card"><span class="admin-label">Academy portfolio</span><h2>Build a library your learners return to.</h2><span class="portfolio-stat"><span>LIVE PROGRAMS</span><br />@ViewBag.TotalCourses active offers</span><svg class="portfolio-lines" viewBox="0 0 400 180" preserveAspectRatio="none" aria-hidden="true"><path d="M0 160 C50 132 75 153 109 118 S160 137 196 91 S245 107 278 70 S335 90 400 18" fill="none" stroke="#36b993" stroke-width="3"/><path d="M0 180 L0 160 C50 132 75 153 109 118 S160 137 196 91 S245 107 278 70 S335 90 400 18 L400 180Z" fill="#86dac1" fill-opacity=".35"/></svg></aside></section>
