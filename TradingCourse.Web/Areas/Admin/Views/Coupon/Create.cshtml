@model TradingCourse.Application.Models.Coupon
@{
    ViewData["Title"] = "Create Promo Coupon";
}

<div class="py-4">
    <div class="mb-4">
        <a asp-action="Index" class="text-secondary text-decoration-none small" id="back-to-list">
            <i class="bi bi-chevron-left"></i> Back to Coupons
        </a>
        <h1 class="text-white fw-bold mb-0 mt-1">Create Promo Coupon</h1>
    </div>

    <div class="glass-card" id="create-coupon-card">
        <form asp-action="Create" method="post" class="needs-validation" novalidate id="create-coupon-form">
            <div class="row g-4">
                <div class="col-md-6">
                    <h3 class="text-white h5 mb-3 border-bottom border-secondary border-opacity-10 pb-2">Campaign Settings</h3>

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label form-label-custom">Coupon Code (Uppercase)</label>
                        <input asp-for="Code" class="form-control form-control-custom font-monospace" placeholder="e.g. TRADER50" required style="text-transform: uppercase;" />
                        <span asp-validation-for="Code" class="invalid-feedback">Coupon code is required.</span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DiscountType" class="form-label form-label-custom">Discount Type</label>
                        <select asp-for="DiscountType" class="form-select form-control-custom" required>
                            <option value="Percentage">Percentage Off (%)</option>
                            <option value="Fixed">Fixed Amount Off (INR)</option>
                        </select>
                        <span asp-validation-for="DiscountType" class="invalid-feedback">Please select a discount type.</span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DiscountValue" class="form-label form-label-custom">Discount Value</label>
                        <input asp-for="DiscountValue" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 10 or 500" required />
                        <span asp-validation-for="DiscountValue" class="invalid-feedback">Please enter a valid discount value.</span>
                    </div>
                </div>

                <div class="col-md-6">
                    <h3 class="text-white h5 mb-3 border-bottom border-secondary border-opacity-10 pb-2">Restrictions & Usage</h3>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label form-label-custom">Restrict to Specific Course (Optional)</label>
                        <select asp-for="CourseId" class="form-select form-control-custom" asp-items="ViewBag.Courses">
                            <option value="">-- Apply to All Courses --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MinPurchaseAmount" class="form-label form-label-custom">Minimum Purchase Amount (Optional)</label>
                        <input asp-for="MinPurchaseAmount" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 1000.00" />
                        <span asp-validation-for="MinPurchaseAmount" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ExpiryDate" class="form-label form-label-custom">Expiry Date (Optional)</label>
                        <input asp-for="ExpiryDate" type="date" class="form-control form-control-custom" />
                        <span asp-validation-for="ExpiryDate" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaxUsage" class="form-label form-label-custom">Total Usage Limit (Optional)</label>
                        <input asp-for="MaxUsage" type="number" class="form-control form-control-custom" placeholder="e.g. 100" />
                        <span asp-validation-for="MaxUsage" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-12 d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-premium btn-lg" id="btn-save-coupon">
                        Create Coupon <i class="bi bi-check-lg ms-1"></i>
                    </button>
                    <a asp-area="Admin" asp-controller="Coupon" asp-action="Index" class="btn btn-outline-custom btn-lg">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Force code input to uppercase
            $('#Code').on('input', function() {
                this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
            });

            // Apply standard validation
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        });
    </script>
}
