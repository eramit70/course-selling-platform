@model IEnumerable<TradingCourse.Application.Models.Coupon>
@{
    ViewData["Title"] = "Manage Coupons";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none small">
                <i class="bi bi-chevron-left"></i> Dashboard
            </a>
            <h1 class="text-white fw-bold mb-0 mt-1">Manage Coupons</h1>
        </div>
        <a asp-action="Create" class="btn btn-premium" id="btn-create-coupon">
            <i class="bi bi-plus-circle me-1"></i> Add Coupon
        </a>
    </div>

    <div class="glass-card" id="admin-coupons-card">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-tags-fill fs-1 text-muted mb-3 d-block"></i>
                <h3 class="text-white">No promotional coupons created</h3>
                <p class="text-secondary mb-4">Click "Add Coupon" above to create discount campaigns.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle" style="border-color: var(--card-border);">
                    <thead>
                        <tr class="text-secondary">
                            <th>ID</th>
                            <th>Coupon Code</th>
                            <th>Discount</th>
                            <th>Active Status</th>
                            <th>Expiry Date</th>
                            <th>Usage Limit</th>
                            <th>Times Used</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var coupon in Model)
                        {
                            bool isActive = (!coupon.ExpiryDate.HasValue || coupon.ExpiryDate.Value > DateTime.UtcNow) && 
                                            (!coupon.MaxUsage.HasValue || coupon.UsedCount < coupon.MaxUsage.Value);
                            <tr>
                                <td class="font-monospace text-muted">#@coupon.Id</td>
                                <td>
                                    <strong class="text-cyan font-monospace">@coupon.Code.ToUpper()</strong>
                                </td>
                                <td>
                                    @if (coupon.DiscountType == TradingCourse.Application.Models.DiscountType.Percentage)
                                    {
                                        <span>@coupon.DiscountValue.ToString("G0")% Off</span>
                                    }
                                    else
                                    {
                                        <span>₹@coupon.DiscountValue.ToString("N2") Off</span>
                                    }
                                </td>
                                <td>
                                    @if (isActive)
                                    {
                                        <span class="badge bg-success bg-opacity-20 text-success border border-success border-opacity-35 px-2 py-1">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-20 text-danger border border-danger border-opacity-35 px-2 py-1">Expired/Used</span>
                                    }
                                </td>
                                <td>@(coupon.ExpiryDate.HasValue ? coupon.ExpiryDate.Value.ToLocalTime().ToString("yyyy-MM-dd") : "Never")</td>
                                <td>@(coupon.MaxUsage.HasValue ? coupon.MaxUsage.Value.ToString() : "Unlimited")</td>
                                <td>@coupon.UsedCount</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@coupon.Id" class="btn btn-sm btn-outline-custom" id="btn-edit-@coupon.Id">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@coupon.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this coupon?');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-danger border-0 bg-opacity-25 text-danger" id="btn-delete-@coupon.Id" style="background-color: rgba(220, 53, 69, 0.15);">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
