@model IEnumerable<TradingCourse.Application.Models.Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none small">
                <i class="bi bi-chevron-left"></i> Dashboard
            </a>
            <h1 class="text-white fw-bold mb-0 mt-1">Manage Courses</h1>
        </div>
        <a asp-action="Create" class="btn btn-premium" id="btn-create-course">
            <i class="bi bi-plus-circle me-1"></i> Add Course
        </a>
    </div>

    <div class="glass-card" id="admin-courses-card">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-plus fs-1 text-muted mb-3 d-block"></i>
                <h3 class="text-white">No courses created yet</h3>
                <p class="text-secondary mb-4">Click "Add Course" above to create your first course offering.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle" style="border-color: var(--card-border);">
                    <thead>
                        <tr class="text-secondary">
                            <th>ID</th>
                            <th>Course Title</th>
                            <th>Instructor</th>
                            <th>Schedule</th>
                            <th>Price</th>
                            <th>Sale Price</th>
                            <th>Type</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td class="font-monospace text-muted">#@course.Id</td>
                                <td>
                                    <strong class="text-white">@course.Title</strong>
                                    <span class="d-block text-secondary small">slug: @course.Slug</span>
                                </td>
                                <td>@course.Instructor</td>
                                <td>@course.Schedule</td>
                                <td>₹@course.Price.ToString("N2")</td>
                                <td>@(course.SalePrice.HasValue ? "₹" + course.SalePrice.Value.ToString("N2") : "None")</td>
                                <td>
                                    @if (course.IsLive)
                                    {
                                        <span class="live-indicator"><span class="live-dot"></span> LIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom">Recorded</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-custom" id="btn-edit-@course.Id">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@course.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this course? This cannot be undone.');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-danger border-0 bg-opacity-25 text-danger" id="btn-delete-@course.Id" style="background-color: rgba(220, 53, 69, 0.15);">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
