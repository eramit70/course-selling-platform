<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APSRA Admin</title>
    <script>document.documentElement.dataset.theme = localStorage.getItem('apsra-theme') || 'light';</script>
    <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .admin-container { display:flex; min-height:100vh; }.admin-sidebar { background:var(--surface); border-right:1px solid var(--line); display:flex; flex-direction:column; padding:28px 18px; position:fixed; inset:0 auto 0 0; width:250px; z-index:10; }.admin-content { flex:1; margin-left:250px; max-width:1600px; min-height:100vh; padding:34px 44px; }.admin-brand { margin:0 10px 38px; }.admin-kicker { color:var(--muted); font:500 .58rem 'DM Mono',monospace; letter-spacing:.11em; margin:0 11px 10px; text-transform:uppercase; }.admin-nav { display:flex; flex-direction:column; gap:5px; list-style:none; margin:0; padding:0; }.admin-nav-link { align-items:center; border:1px solid transparent; border-radius:6px; color:var(--muted); display:flex; font-size:.77rem; font-weight:700; gap:12px; padding:11px 12px; text-decoration:none; transition:.2s; }.admin-nav-link i { font-size:1rem; }.admin-nav-link:hover { background:var(--soft); color:var(--ink); }.admin-nav-link.active { background:var(--mint); border-color:color-mix(in srgb,var(--mint-strong) 45%,transparent); color:#167054; }.admin-nav-link .bi-box-arrow-up-right { font-size:.65rem; margin-left:auto; }.admin-footer { border-top:1px solid var(--line); margin-top:auto; padding:18px 10px 0; }.admin-footer small { color:var(--muted); display:block; font-size:.63rem; line-height:1.5; margin-bottom:12px; }.admin-signout { background:none; border:0; color:#bd594b; font-size:.72rem; font-weight:800; padding:0; }.admin-mobile-bar { display:none; }.admin-content .table { --bs-table-bg:transparent; --bs-table-color:var(--ink); --bs-table-hover-bg:var(--soft); --bs-table-hover-color:var(--ink); border-color:var(--line)!important; font-size:.76rem; }.admin-content .table thead th { border-bottom-width:1px; color:var(--muted); font:500 .62rem 'DM Mono',monospace; letter-spacing:.06em; text-transform:uppercase; }.admin-content .table td,.admin-content .table th { border-color:var(--line); padding:.9rem .7rem; }.admin-content .btn-outline-custom { border:1px solid var(--line); border-radius:6px; color:var(--ink)!important; font-size:.76rem; font-weight:700; padding:.68rem .9rem; }.admin-content .btn-outline-custom:hover { background:var(--soft); }.admin-content .form-label-custom { color:var(--muted); font-size:.7rem; font-weight:700; }.admin-content .alert-success { color:#137455!important; }.admin-content .alert-danger { color:#bd4c3d!important; } html[data-theme='dark'] .admin-nav-link.active { color:#75ebc6; } html[data-theme='dark'] .admin-nav-link.active { background:#1c4136; }.admin-top { align-items:center; display:flex; justify-content:flex-end; margin-bottom:25px; }.admin-view-link { color:var(--muted); font-size:.72rem; font-weight:700; text-decoration:none; }.admin-view-link:hover { color:var(--ink); }
        @@media(max-width:991px) { .admin-sidebar { display:none; }.admin-content { margin-left:0; padding:22px; }.admin-mobile-bar { align-items:center; border-bottom:1px solid var(--line); display:flex; justify-content:space-between; padding:14px 22px; }.admin-mobile-links { display:flex; gap:14px; }.admin-mobile-links a { color:var(--muted); font-size:.7rem; font-weight:700; text-decoration:none; } } @@media(max-width:576px) { .admin-content { padding:18px 14px; } }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="admin-mobile-bar"><a class="navbar-brand" href="/Admin"><span class="brand-mark">A</span><span>apsra<span class="brand-dot">.</span></span></a><div class="admin-mobile-links"><a href="/Admin">Overview</a><a href="/Admin/Course">Courses</a><a href="/">View site</a></div></div>
    <div class="admin-container"><aside class="admin-sidebar"><a class="navbar-brand admin-brand" href="/Admin"><span class="brand-mark">A</span><span>apsra<span class="brand-dot">.</span></span></a><p class="admin-kicker">Workspace</p><ul class="admin-nav"><li><a href="/Admin" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"><i class="bi bi-grid-1x2"></i> Overview</a></li><li><a href="/Admin/Course" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Course" ? "active" : "")"><i class="bi bi-collection-play"></i> Programs</a></li><li><a href="/Admin/Order" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"><i class="bi bi-people"></i> Enrolments</a></li><li><a href="/Admin/Coupon" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")"><i class="bi bi-ticket-perforated"></i> Coupons</a></li><li><a href="/Admin/HomepageBanner" class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HomepageBanner" ? "active" : "")"><i class="bi bi-layout-text-window"></i> Homepage content</a></li></ul><p class="admin-kicker mt-4">System</p><ul class="admin-nav"><li><a href="/admin/hangfire" target="_blank" class="admin-nav-link"><i class="bi bi-cpu"></i> Background jobs <i class="bi bi-box-arrow-up-right"></i></a></li><li><a href="/" class="admin-nav-link"><i class="bi bi-arrow-up-right-circle"></i> View public site</a></li></ul><div class="admin-footer"><small>APSRA management workspace<br />All changes are published live.</small><form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="admin-signout"><i class="bi bi-box-arrow-left me-1"></i> Sign out</button></form></div></aside><main class="admin-content"><div class="admin-top"><button class="theme-toggle" type="button" id="theme-toggle" aria-label="Switch color theme"><i class="bi bi-sun-fill"></i><i class="bi bi-moon-stars-fill"></i></button></div>
        @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @if (TempData["ErrorMessage"] != null) { <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @RenderBody()
    </main></div><script src="~/lib/jquery/dist/jquery.min.js"></script><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script><script src="~/js/site.js" asp-append-version="true"></script>@await RenderSectionAsync("Scripts", required: false)
</body></html>
